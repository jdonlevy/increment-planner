generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model Event {
  id         String      @id @default(cuid())
  name       String
  days       String[]
  slots      String[]
  lunchSlots Int[]
  lunchLabel String     @default("Lunch Break")
  createdAt  DateTime    @default(now())
  sessions   Session[]
  placements Placement[]
  blocked    Blocked[]
}

model Room {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now())
  blocked    Blocked[]
  placements Placement[]
  teams      Team[]
}

model Team {
  id        String    @id @default(cuid())
  name      String
  colorIdx  Int       @default(0)
  roomId    String?
  createdAt DateTime  @default(now())
  people    Person[]
  sessions  Session[]
  room      Room?     @relation(fields: [roomId], references: [id])
}

model Person {
  id        String    @id @default(cuid())
  name      String
  teamId    String
  createdAt DateTime  @default(now())
  team      Team      @relation(fields: [teamId], references: [id])
  sessions  Session[] @relation("SessionAttendees")
}

model Session {
  id         String      @id @default(cuid())
  name       String
  notes      String      @default("")
  crossTeam  Boolean     @default(false)
  teamId     String
  eventId    String?
  createdAt  DateTime    @default(now())
  placements Placement[]
  event      Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  team       Team        @relation(fields: [teamId], references: [id])
  attendees  Person[]    @relation("SessionAttendees")
}

model Placement {
  id        String   @id @default(cuid())
  sessionId String
  roomId    String
  day       String
  slotIdx   Int
  eventId   String?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  room      Room     @relation(fields: [roomId], references: [id])
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([roomId, day, slotIdx, eventId])
}

model Blocked {
  id        String   @id @default(cuid())
  roomId    String
  day       String
  slotIdx   Int
  eventId   String?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  room      Room     @relation(fields: [roomId], references: [id])

  @@unique([roomId, day, slotIdx, eventId])
}
