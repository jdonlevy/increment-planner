generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Room {
  id         String      @id @default(cuid())
  name       String
  createdAt  DateTime    @default(now())
  blocked    Blocked[]
  placements Placement[]
  teams      Team[]
}

model Team {
  id        String    @id @default(cuid())
  name      String
  colorIdx  Int       @default(0)
  roomId    String
  createdAt DateTime  @default(now())
  people    Person[]
  sessions  Session[]
  room      Room      @relation(fields: [roomId], references: [id])
}

model Person {
  id        String    @id @default(cuid())
  name      String
  teamId    String
  createdAt DateTime  @default(now())
  team      Team      @relation(fields: [teamId], references: [id])
  sessions  Session[] @relation("SessionAttendees")
}

model Session {
  id         String      @id @default(cuid())
  name       String
  notes      String      @default("")
  teamId     String
  createdAt  DateTime    @default(now())
  placements Placement[]
  team       Team        @relation(fields: [teamId], references: [id])
  attendees  Person[]    @relation("SessionAttendees")
}

model Placement {
  id        String   @id @default(cuid())
  sessionId String
  roomId    String
  day       String
  slotIdx   Int
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id])
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([roomId, day, slotIdx])
}

model Blocked {
  id        String   @id @default(cuid())
  roomId    String
  day       String
  slotIdx   Int
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id])

  @@unique([roomId, day, slotIdx])
}
